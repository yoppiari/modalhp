---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

// Need to encode current URL for sharing. We use Astro.url.href.
const shareUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);

---

<html lang="id">
	<head>
		<BaseHead title={`${title} - ModalHP Blog`} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"image": heroImage ? new URL(heroImage.src, Astro.url) : undefined,
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"author": [{
				"@type": "Organization",
				"name": "Modal HP",
				"url": "https://modalhp.com"
			}]
		})} />
		<style>
			/* Styling standard elements in Markdown output */
			.blog-content h1, .blog-content h2, .blog-content h3, .blog-content h4 { color: #0f172a; font-weight: 800; line-height: 1.3; }
			.blog-content h1 { font-size: 2.25rem; margin-top: 2.5rem; margin-bottom: 1.25rem; }
			.blog-content h2 { font-size: 1.875rem; margin-top: 2.5rem; margin-bottom: 1.25rem; }
			.blog-content h3 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
			.blog-content p { margin-bottom: 1.5rem; font-size: 1.125rem; color: #334155; }
			.blog-content ul { list-style-type: disc; padding-left: 1.75rem; margin-bottom: 1.5rem; font-size: 1.125rem; color: #334155; }
			.blog-content ol { list-style-type: decimal; padding-left: 1.75rem; margin-bottom: 1.5rem; font-size: 1.125rem; color: #334155; }
			.blog-content li { margin-bottom: 0.5rem; }
			.blog-content li::marker { color: #64748b; }
			.blog-content a { color: #2563eb; font-weight: 600; text-decoration: none; border-bottom: 2px solid #bfdbfe; transition: all 0.2s; }
			.blog-content a:hover { color: #1d4ed8; border-bottom-color: #2563eb; }
			.blog-content strong { font-weight: 700; color: #0f172a; }
			.blog-content blockquote { border-left: 4px solid #3b82f6; background-color: #f8fafc; padding: 1.25rem 1.5rem; margin: 2rem 0; border-radius: 0 1rem 1rem 0; font-style: italic; color: #475569; font-size: 1.25rem; }
			.blog-content img { border-radius: 1rem; margin: 2rem auto; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); width: 100%; object-fit: cover; }
			.blog-content hr { margin: 3rem 0; border: 0; border-top: 2px dashed #e2e8f0; }
		</style>
	</head>

	<body class="bg-slate-50 text-slate-700 font-sans min-h-screen flex flex-col selection:bg-blue-200 selection:text-blue-900">
		<Header />
		
		<main class="flex-grow pt-28 pb-20 px-6">
			<article class="max-w-3xl mx-auto">
				
				<!-- Readability First: Title & Meta at the top -->
				<header class="mb-10 text-center">
					<div class="flex items-center justify-center gap-3 mb-6">
						<span class="inline-flex items-center px-4 py-1.5 rounded-full bg-blue-100 text-blue-700 text-sm font-bold uppercase tracking-widest shadow-sm">
							<FormattedDate date={pubDate} />
						</span>
					</div>
					
					<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-slate-900 mb-6 tracking-tight">
						{title}
					</h1>
					
					<p class="text-xl text-slate-500 font-medium max-w-2xl mx-auto mb-8 leading-relaxed">
						{description}
					</p>

					<!-- Horizontal Share Buttons below title -->
					<div class="flex items-center justify-center gap-4 py-6 border-y border-slate-200/60 mb-8">
						<span class="text-sm font-bold text-slate-400 uppercase tracking-widest mr-2">Bagikan:</span>
						
						<!-- WhatsApp -->
						<a href={`https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share di WhatsApp" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-green-600 hover:bg-green-600 hover:text-white transition-all hover:scale-110">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
						</a>
						<!-- Twitter / X -->
						<a href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share di X" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-700 hover:bg-slate-900 hover:text-white transition-all hover:scale-110">
							<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>
						<!-- Facebook -->
						<a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share di Facebook" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-blue-600 hover:bg-blue-600 hover:text-white transition-all hover:scale-110">
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
						</a>
						<!-- Copy Link -->
						<button onclick={`navigator.clipboard.writeText('${shareUrl}'); alert('Tautan berhasil disalin!');`} aria-label="Salin Tautan" class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-slate-300 hover:text-slate-900 transition-all hover:scale-110">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
						</button>
					</div>
				</header>

				<!-- Elegant Hero Image Below Title -->
				{heroImage && (
					<div class="w-full aspect-video rounded-3xl overflow-hidden bg-slate-100 mb-12 shadow-xl shadow-slate-200/50">
						<Image 
							width={1200} 
							height={675} 
							src={heroImage} 
							alt={title}
							class="w-full h-full object-cover" 
						/>
					</div>
				)}

				<!-- Main Article Content -->
				<div class="blog-content w-full leading-relaxed bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-slate-100">
					<slot />

					<!-- Read More Banner CTA -->
					<div class="mt-16 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-3xl p-8 md:p-10 text-center shadow-lg shadow-blue-200/50 relative overflow-hidden">
						<div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
						<h3 class="text-2xl md:text-3xl font-extrabold text-white mb-4 relative z-10">Kembangkan Bisnis Anda Hari Ini</h3>
						<p class="text-blue-100 mb-8 max-w-xl mx-auto font-medium relative z-10">Gunakan kumpulan tool cerdas untuk UMKM (Kasir, Stok, Laporan Keuangan). 100% Gratis dan aman di HP Anda.</p>
						<a href="/apps/login" class="inline-flex items-center justify-center gap-2 bg-white text-blue-700 hover:bg-slate-50 hover:text-blue-800 font-extrabold py-3.5 px-8 rounded-full shadow-lg transition-transform hover:-translate-y-1 relative z-10">
							Buka ModalHP
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
						</a>
					</div>
				</div>
				
			</article>
		</main>
		
		<Footer />
	</body>
</html>
